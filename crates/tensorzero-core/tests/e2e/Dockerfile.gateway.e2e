# ========== builder ==========

FROM rust:1.93.0-slim AS builder

WORKDIR /src
ENV CARGO_INCREMENTAL=0

RUN apt-get update && apt-get install -y clang libc++-dev mold && rm -rf /var/lib/apt/lists/*
ENV CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold"
ENV CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_RUSTFLAGS="-C link-arg=-fuse-ld=mold"

COPY crates/ crates/

# Enable the e2e_tests feature by default for the gateway build
ARG CARGO_BUILD_FLAGS="--features e2e_tests"

WORKDIR /src/crates
RUN cargo build -p gateway $CARGO_BUILD_FLAGS && \
    mkdir -p /release && \
    cp /src/crates/target/debug/gateway /release/gateway

# ========== base ==========

FROM debian:trixie-slim AS base

RUN apt-get update && apt-get install -y ca-certificates openssl wget && rm -rf /var/lib/apt/lists/*

# ========== gateway ==========

FROM base AS gateway

RUN useradd -m -s /bin/bash gateway

USER gateway

COPY --from=builder /release/gateway /usr/local/bin/gateway

WORKDIR /app

EXPOSE 3000

ENTRYPOINT ["gateway"]
